#!/usr/bin/env bash

# Report resident memory (RSS) for all visible process owners to Zabbix.
# Runtime dependencies: bash, ps, awk, and sort.

set -o errexit
set -o nounset
set -o pipefail

readonly PROGRAM_NAME="${0##*/}"

die() {
    printf '%s: %s\n' "$PROGRAM_NAME" "$*" >&2
    exit 1
}

usage() {
    printf 'Usage: %s collect\n' "$PROGRAM_NAME" >&2
    exit 2
}

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

json_escape() {
    local value=$1

    value=${value//\\/\\\\}
    value=${value//\"/\\\"}
    value=${value//$'\n'/\\n}
    value=${value//$'\r'/\\r}
    value=${value//$'\t'/\\t}
    printf '%s' "$value"
}

collect() {
    local ps_output aggregated username uid bytes
    local first=1

    for dependency in ps awk sort; do
        command_exists "$dependency" || die "required command not found: $dependency"
    done

    # Aggregate by numeric UID so display-width truncation cannot split or lose
    # an account. The wide USER field preserves long names for the JSON label.
    # ps reports RSS in KiB; convert the total to bytes for Zabbix.
    ps_output=$(LC_ALL=C ps -eo uid=,user:256=,rss=) || die 'could not read the process table'
    aggregated=$(awk '
        $1 ~ /^[0-9]+$/ && $2 != "" && $3 ~ /^[0-9]+$/ {
            username[$1] = $2
            rss_kib[$1] += $3
        }
        END {
            for (uid in rss_kib) {
                printf "%s %s %.0f\n", username[uid], uid, rss_kib[uid] * 1024
            }
        }
    ' <<<"$ps_output" | sort -k1,1 -k2,2n)

    printf '{"users":['
    while read -r username uid bytes; do
        [[ -n ${username:-} ]] || continue

        if (( first == 0 )); then
            printf ','
        fi
        first=0
        printf '{"user":"%s","bytes":%s}' \
            "$(json_escape "$username")" "$bytes"
    done <<<"$aggregated"
    printf ']}\n'
}

[[ $# -eq 1 ]] || usage

case $1 in
    collect)
        collect
        ;;
    *)
        usage
        ;;
esac
