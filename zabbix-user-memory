#!/usr/bin/env bash

# Report resident memory (RSS) for currently logged-in users to Zabbix.
# Runtime dependencies: bash, who, ps, awk, and sort.

set -o errexit
set -o nounset
set -o pipefail

readonly PROGRAM_NAME="${0##*/}"

die() {
    printf '%s: %s\n' "$PROGRAM_NAME" "$*" >&2
    exit 1
}

usage() {
    printf 'Usage: %s collect\n' "$PROGRAM_NAME" >&2
    exit 2
}

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

json_escape() {
    local value=$1

    value=${value//\\/\\\\}
    value=${value//\"/\\\"}
    value=${value//$'\n'/\\n}
    value=${value//$'\r'/\\r}
    value=${value//$'\t'/\\t}
    printf '%s' "$value"
}

collect() {
    local who_output online_users ps_output aggregated username bytes
    local first=1
    declare -A rss_bytes=()

    for dependency in who ps awk sort; do
        command_exists "$dependency" || die "required command not found: $dependency"
    done

    # Keep only users with a current login record. Multiple sessions belonging
    # to the same user are collapsed into one entry.
    who_output=$(LC_ALL=C who) || die 'could not read login records'
    online_users=$(awk 'NF >= 1 { print $1 }' <<<"$who_output" | sort -u)

    if [[ -z $online_users ]]; then
        printf '{"users":[]}\n'
        return
    fi

    # Sum the RSS column exactly once per process owner. ps reports RSS in KiB;
    # the JSON value is converted to bytes for Zabbix.
    ps_output=$(LC_ALL=C ps -eo user=,rss=) || die 'could not read the process table'
    aggregated=$(awk '
        $1 != "" && $2 ~ /^[0-9]+$/ {
            rss_kib[$1] += $2
        }
        END {
            for (user in rss_kib) {
                printf "%s %.0f\n", user, rss_kib[user] * 1024
            }
        }
    ' <<<"$ps_output" | sort -k1,1)

    while read -r username bytes; do
        [[ -n ${username:-} ]] || continue
        rss_bytes[$username]=$bytes
    done <<<"$aggregated"

    printf '{"users":['
    while read -r username; do
        [[ -n ${username:-} ]] || continue
        bytes=${rss_bytes[$username]:-0}

        if (( first == 0 )); then
            printf ','
        fi
        first=0
        printf '{"user":"%s","bytes":%s}' \
            "$(json_escape "$username")" "$bytes"
    done <<<"$online_users"
    printf ']}\n'
}

[[ $# -eq 1 ]] || usage

case $1 in
    collect)
        collect
        ;;
    *)
        usage
        ;;
esac
